{
  "name": "noteflow",
  "private": true,
  "version": "1.1.0",
  "description": "Fast notes for software engineers",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.electron.json && wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build && tsc -p tsconfig.electron.json",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "lint": "eslint .",
    "dist": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@tiptap/core": "^2.27.2",
    "@tiptap/extension-bold": "^2.27.2",
    "@tiptap/extension-bullet-list": "^2.27.2",
    "@tiptap/extension-code": "^2.27.2",
    "@tiptap/extension-code-block-lowlight": "^2.27.2",
    "@tiptap/extension-document": "^2.27.2",
    "@tiptap/extension-hard-break": "^2.27.2",
    "@tiptap/extension-heading": "^2.27.2",
    "@tiptap/extension-history": "^2.27.2",
    "@tiptap/extension-horizontal-rule": "^2.27.2",
    "@tiptap/extension-italic": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-list-item": "^2.27.2",
    "@tiptap/extension-ordered-list": "^2.27.2",
    "@tiptap/extension-paragraph": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/extension-strike": "^2.27.2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/extension-text": "^2.27.2",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "date-fns": "^4.1.0",
    "js-yaml": "^4.1.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.513.0",
    "nanoid": "^5.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/electron": "^1.6.10",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "dev.noteflow.notes",
    "productName": "NoteFlow",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  }
}
